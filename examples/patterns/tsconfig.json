{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@revolt-rai/js": ["../../src/index.ts"]
    }
  },
  "include": ["./**/*.tsx", "./**/*.ts"],
  "exclude": ["node_modules"]
}
